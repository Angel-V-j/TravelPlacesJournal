<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Добре дошли в Журнала за пътувания!"
        android:textSize="18sp"
        android:textColor="#333333"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <Button
        android:id="@+id/btnGoToProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Към моя Профил"
        android:backgroundTint="#007BFF"
        android:textColor="#FFFFFF"
        android:textSize="16sp" />
    <Button
        android:id="@+id/btnAdminPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Администраторски Панел"
        android:backgroundTint="#20c997"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />
    <Button
        android:id="@+id/btnPlaces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Places"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnAddPlace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Place"
        android:layout_marginBottom="12dp"/>
</LinearLayout>